generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt-hashed; null for OAuth-only users
  role          String    @default("customer") // "customer" | "admin"
  phone         String?
  // Saved address — reused to prefill coffee checkout shipping step
  address       String?
  apt           String?
  city          String?
  state         String?
  zip           String?
  country       String?
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

// Required by NextAuth Prisma adapter for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Required by NextAuth Prisma adapter (used for OAuth; credentials uses JWT)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Required by NextAuth for email magic links / verification
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Orders ──────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  // Real Stripe PaymentIntent id, or a synthetic `giftcard_<cuid>` id for
  // orders fully covered by gift card balance (no card charge at all).
  stripePaymentId String      @unique
  amount          Float
  currency        String      @default("usd")
  status          String      @default("paid") // paid | partially_refunded | refunded | disputed
  // Cumulative dollars actually refunded via Stripe so far (mirrors the
  // charge's amount_refunded) — only a full refund of the card-charged
  // portion triggers gift card reconciliation; see updateOrderStatus.
  refundedAmount  Float?
  customerEmail   String?
  customerName    String?
  shippingAddress Json?
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Set by the charge.dispute.created/closed webhook handlers — lets the
  // admin orders page show chargeback details without ever needing the
  // Stripe Dashboard. disputeStatus mirrors Stripe's dispute.status
  // (needs_response | under_review | won | lost, etc.); a "lost" dispute
  // triggers the same gift card reconciliation as a full refund.
  disputeId       String?
  disputeReason   String?
  disputeStatus   String?
  disputeDueBy    DateTime?

  // Set when an admin records an order manually (comp, phone/in-person
  // sale, goodwill adjustment) rather than it coming through checkout —
  // stripePaymentId is a synthetic `manual_<cuid>` for these, same pattern
  // as the gift-card-only zero-charge path. Kept separate from the refund/
  // dispute audit trail since it answers a different question ("why does
  // this order exist at all") rather than "what happened to a real charge."
  manualEntryBy   String?
  manualEntryNote String?

  // Gift card redemption — this order applied one or more gift cards toward its total
  giftCardRedemptions GiftCardRedemption[]

  // Gift card purchase — this order is the one where one or more gift cards were bought
  giftCardsPurchased GiftCard[] @relation("GiftCardPurchase")

  @@index([customerEmail])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

// A redeemable e-gift card. Created when a gift-type OrderItem's order is paid;
// spent (partially or fully, across any number of future orders) by code at checkout.
model GiftCard {
  id              String               @id @default(cuid())
  code            String               @unique
  initialBalance  Float
  balance         Float
  senderName      String?
  recipientEmail  String
  message         String?
  purchaseOrderId String?
  purchaseOrder   Order?               @relation("GiftCardPurchase", fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  redemptions     GiftCardRedemption[]
  auditLog        GiftCardAuditLog[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Delivery — every card is created with delivered:false and only flips to
  // true once the email actually sends successfully (immediate or via the
  // scheduled-delivery cron), so "delivered" always reflects a real send,
  // not just that the card was created. `deliverOn` doubles as the retry
  // gate: immediate cards default it to "now" so a failed send is picked up
  // and retried by the same daily cron that handles genuinely scheduled
  // (e.g. birthday) deliveries — one retry mechanism for both cases.
  // Undelivered cards are invisible everywhere (dashboard, validate,
  // redemption) until delivered flips true, so a surprise gift isn't
  // spoiled early and an un-sent code can't be guessed and redeemed blind.
  deliverOn DateTime?
  delivered Boolean   @default(false)

  holds GiftCardHold[]

  @@index([recipientEmail])
  @@index([delivered, deliverOn])
}

// A temporary reservation against a gift card's balance, created the moment
// checkout applies it — whether that order ends up fully covered (paymentIntentId
// is a synthetic `giftcard_<uuid>`, settled in the same request) or partly
// charged via a real Stripe PaymentIntent (settled later by the webhook).
// Always created before the balance is trusted for anything downstream, so
// the amount shown to the customer always matches a real reservation — see
// reserveGiftCards. fulfillOrder's holdsAlreadyReserved mode reads pending
// holds by paymentIntentId as the sole source of truth for what to redeem,
// rather than trusting (possibly stale) PaymentIntent metadata:
//   - pending:  reserved, order not yet finalized
//   - consumed: order created — converted into a real GiftCardRedemption
//   - released: payment intent was canceled or the checkout was abandoned
//               long enough for the release-stale-gift-card-holds cron to
//               reclaim it — amount restored to balance
// Deliberately NOT released on a single failed payment attempt
// (payment_intent.payment_failed) — Stripe commonly reuses the same
// PaymentIntent for a retry after a declined card, so releasing on the
// first failure would let a later successful retry settle against a hold
// that's already gone. Only a genuinely terminal state (canceled, or long
// enough that the cron calls it abandoned) releases the reservation.
model GiftCardHold {
  id              String    @id @default(cuid())
  giftCardId      String
  giftCard        GiftCard  @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  // Denormalized so settlement never has to trust PaymentIntent metadata —
  // fulfillOrder's holdsAlreadyReserved mode reads pending holds straight
  // from this table as the source of truth for what to redeem.
  code            String
  paymentIntentId String
  amount          Float
  status          String    @default("pending") // pending | consumed | released
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  @@index([giftCardId])
  @@index([paymentIntentId])
  @@index([status, createdAt])
}

// Join row — one order can redeem multiple gift cards, and one gift card can
// be redeemed (partially) across many separate orders over time.
model GiftCardRedemption {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  amount     Float
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([giftCardId])
}

// One row per run of the scheduled-gift-card-delivery cron job — lets the
// admin gift cards page show "last ran at X" so a silently-disabled or
// misconfigured Vercel Cron is visible instead of failing invisibly.
model CronRun {
  id      String   @id @default(cuid())
  job     String
  ranAt   DateTime @default(now())
  checked Int
  sent    Int

  @@index([job, ranAt])
}

// Logged the instant a Stripe webhook event passes signature verification —
// exists purely so the admin dashboard can show "Stripe last talked to us
// at X" without ever needing Stripe Dashboard's own webhook event log. Born
// directly from this project hitting a silently-dead webhook twice during
// development (see the orphaned-payment recovery tool this pairs with).
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  receivedAt    DateTime @default(now())

  @@index([receivedAt])
}

// Durable, queryable record of admin actions on gift cards — issue, credit,
// resend — so "who issued this $500 card and why" is a query, not a log grep.
model GiftCardAuditLog {
  id         String   @id @default(cuid())
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  action     String   // issue | credit | resend | void
  amount     Float?
  reason     String?
  adminEmail String
  createdAt  DateTime @default(now())

  @@index([giftCardId])
}

model OrderItem {
  id                 String    @id @default(cuid())
  orderId            String
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId          String
  name               String
  variant            String
  price              Float
  qty                Int
  giftRecipientEmail String?
  giftMessage        String?
  giftDeliverOn      DateTime?
}

// ─── Products ────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  type        String   // coffee | subscription | merch
  name        String
  subtitle    String?
  description String?  @db.Text
  price       Float
  // Coffee-specific
  origin      String?
  region      String?  // Africa | Latin America | Central America | Asia Pacific | Other
  process     String?
  elevation   String?
  roast       String?
  notes       String[]
  prices      Json?    // { "12 oz": 22, "5 lb": 85 }
  // Subscription-specific
  freq        String?
  period      String?
  features    String[]
  // Merch-specific
  options     String[]
  // Common display
  gradient    String?
  icon        String?
  badge       String?
  badgeClass  String?
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  position    Int      @default(0)
  salesRank   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([position])
  @@index([salesRank])
}

// ─── Site Content ────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  page      String   // home | about | contact | wholesale
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([page, key])
  @@index([page])
}

// ─── Submissions ─────────────────────────────────────────────

model Submission {
  id          String              @id @default(cuid())
  type        String              // CONTACT | WHOLESALE | CART
  data        Json                // raw form fields
  senderName  String?
  senderEmail String
  read        Boolean             @default(false)
  messages    SubmissionMessage[]
  createdAt   DateTime            @default(now())

  @@index([type])
  @@index([read])
  @@index([createdAt])
}

model SubmissionMessage {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  direction    String     // OUTBOUND (admin -> sender) | INBOUND (sender's email reply)
  body         String     @db.Text
  createdAt    DateTime   @default(now())

  @@index([submissionId])
}
