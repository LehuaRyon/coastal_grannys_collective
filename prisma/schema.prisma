generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt-hashed; null for OAuth-only users
  role          String    @default("customer") // "customer" | "admin"
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

// Required by NextAuth Prisma adapter for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Required by NextAuth Prisma adapter (used for OAuth; credentials uses JWT)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Required by NextAuth for email magic links / verification
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Orders ──────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  stripePaymentId String      @unique
  amount          Float
  currency        String      @default("usd")
  status          String      @default("paid") // paid | refunded | disputed
  customerEmail   String?
  customerName    String?
  shippingAddress Json?
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerEmail])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  variant   String
  price     Float
  qty       Int
}

// ─── Products ────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  type        String   // coffee | subscription | merch
  name        String
  subtitle    String?
  description String?  @db.Text
  price       Float
  // Coffee-specific
  origin      String?
  region      String?  // Africa | Latin America | Central America | Asia Pacific | Other
  process     String?
  elevation   String?
  roast       String?
  notes       String[]
  prices      Json?    // { "12 oz": 22, "5 lb": 85 }
  // Subscription-specific
  freq        String?
  period      String?
  features    String[]
  // Merch-specific
  options     String[]
  // Common display
  gradient    String?
  icon        String?
  badge       String?
  badgeClass  String?
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  position    Int      @default(0)
  salesRank   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([position])
  @@index([salesRank])
}

// ─── Site Content ────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  page      String   // home | about | contact | wholesale
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([page, key])
  @@index([page])
}
